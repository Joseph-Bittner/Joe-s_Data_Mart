@model DeveloperJosephBittner.DataMart.Models.SqlTestViewModel
@{
    ViewData["Title"] = "SQL Test";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-6 sm:p-8 lg:p-10">
        <div class="mb-8">
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-800">SQL Test Document</h1>
            <p class="mt-2 text-gray-600">Run a simple query and display the <strong>TimeOfDay</strong> result.</p>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4 sm:p-6">
            <p class="text-sm font-semibold text-gray-700 mb-2">Query</p>
            <pre class="overflow-x-auto rounded-lg bg-gray-900 text-green-200 text-sm p-4">@Model.Query</pre>

            <form asp-action="SqlTest" method="post" class="mt-4">
                <button type="submit"
                        class="bg-gradient-to-r from-datamart-primary to-datamart-secondary text-white font-semibold py-3 px-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-200">
                    Run Query
                </button>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Error))
        {
            <div class="mt-6 rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-red-700">
                @Model.Error
            </div>
        }

        @if (Model.TimeOfDayResults.Count > 0)
        {
            <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-6">
                <p class="text-sm font-medium text-emerald-800">Results (@Model.TimeOfDayResults.Count rows)</p>
                <div class="mt-3 overflow-x-auto rounded-lg border border-emerald-200 bg-white">
                    <table class="min-w-full divide-y divide-emerald-100">
                        <thead class="bg-emerald-100/60">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-emerald-900 uppercase tracking-wider">TimeOfDay</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-emerald-50">
                            @foreach (var value in Model.TimeOfDayResults)
                            {
                                <tr>
                                    <td class="px-4 py-2 text-sm text-emerald-900">@value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>