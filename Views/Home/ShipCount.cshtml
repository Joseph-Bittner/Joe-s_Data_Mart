@model DeveloperJosephBittner.DataMart.Models.ShipCountViewModel
@{
    ViewData["Title"] = "Ship Count";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-6 sm:p-8 lg:p-10">
        <div class="mb-8">
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-800">Ship Count</h1>
            <p class="mt-2 text-gray-600">Search an item number to see shipment rows from DETAL1, then click a shipment to view details from DETAL1 + STAGE.</p>
        </div>

        <form asp-action="ShipCount" method="post" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div class="md:col-span-3">
                <label for="ItemNumber" class="block text-sm font-semibold text-gray-700 mb-2">Item Number</label>
                <input asp-for="ItemNumber" id="ItemNumber" type="text" placeholder="e.g. 151018"
                       class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-datamart-primary focus:outline-none" />
            </div>

            <div>
                <button type="submit"
                        class="w-full bg-gradient-to-r from-datamart-primary to-datamart-secondary text-white font-semibold py-3 px-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-200">
                    Search Item
                </button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.Error))
        {
            <div class="mt-6 rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-red-700">
                @Model.Error
            </div>
        }

        @if (Model.Result != null)
        {
            <div class="mt-8 space-y-6">
                @* Summary cards for the selected item and aggregate metrics. *@
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
                    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-blue-100 p-5 border border-blue-200">
                        <p class="text-sm text-blue-700 font-medium">Item</p>
                        <p class="text-2xl font-bold text-blue-900 mt-1">@Model.Result.Summary.ItemNumber</p>
                    </div>
                    <div class="rounded-2xl bg-gradient-to-br from-emerald-50 to-emerald-100 p-5 border border-emerald-200">
                        <p class="text-sm text-emerald-700 font-medium">Shipment Rows</p>
                        <p class="text-2xl font-bold text-emerald-900 mt-1">@Model.Result.Summary.ShipmentCount</p>
                    </div>
                    <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-amber-100 p-5 border border-amber-200">
                        <p class="text-sm text-amber-700 font-medium">Total Qty Shipped</p>
                        <p class="text-2xl font-bold text-amber-900 mt-1">@Model.Result.Summary.TotalQuantityShipped.ToString("N2")</p>
                    </div>
                    <div class="cost-reveal-card rounded-2xl bg-white p-5 border border-rose-200 shadow-sm" tabindex="0">
                        <p class="text-sm text-rose-700 font-medium">Total Cost of Shipped</p>
                        <p class="text-2xl font-bold text-gray-900 mt-1">
                            <span class="cost-mask">*****</span>
                            <span class="cost-value">@Model.Result.Summary.TotalCostShipped.ToString("C2")</span>
                        </p>
                    </div>
                </div>

                @if (Model.Result.Shipments.Count == 0)
                {
                    <div class="rounded-xl border border-yellow-300 bg-yellow-50 px-4 py-3 text-yellow-800">
                        No shipment rows found for this item in DETAL1.
                    </div>
                }
                else
                {
                    @* Main shipment table. Each row can expand inline to show detailed values. *@
                    <div class="rounded-2xl border border-gray-200 overflow-hidden">
                        <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                            <h2 class="text-lg font-semibold text-gray-800">Shipment Results</h2>
                            <p class="text-sm text-gray-600">Click View Details to expand shipment stats.</p>
                        </div>
                        <div class="overflow-x-auto max-h-[34rem]">
                            <table class="min-w-full divide-y divide-gray-200 bg-white">
                                <thead class="bg-gray-50 sticky top-0">
                                    <tr>
                                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Key</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Item Name</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Load Date</th>
                                        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Qty</th>
                                        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @for (var i = 0; i < Model.Result.Shipments.Count; i++)
                                    {
                                        var shipment = Model.Result.Shipments[i];
                                        var panelId = $"shipment-details-{i}";
                                        <tr class="hover:bg-gray-50">
                                            <td class="px-4 py-3 text-sm text-gray-800 font-medium">@shipment.ShipmentKey</td>
                                            <td class="px-4 py-3 text-sm text-gray-700">@(string.IsNullOrWhiteSpace(shipment.Description) ? "(No description)" : shipment.Description)</td>
                                            <td class="px-4 py-3 text-sm text-gray-700">
                                                @(
                                                    shipment.LoadDate.HasValue
                                                        ? shipment.LoadDate.Value.ToString("yyyy-MM-dd")
                                                        : (!string.IsNullOrWhiteSpace(shipment.LoadDateRaw) ? shipment.LoadDateRaw : "N/A")
                                                )
                                            </td>
                                            <td class="px-4 py-3 text-sm text-gray-800 text-right font-semibold">@shipment.QuantityShipped.ToString("N2")</td>
                                            <td class="px-4 py-3 text-right">
                                                <button type="button"
                                                        class="inline-flex items-center rounded-lg px-3 py-2 text-xs font-semibold text-white transition-colors"
                                                        style="background-color:#000000;border:1px solid #000000;"
                                                        onmouseover="this.style.backgroundColor='#111827'"
                                                        onmouseout="this.style.backgroundColor='#000000'"
                                                        onclick="toggleShipmentDetails('@panelId', this)">
                                                    View Details
                                                </button>
                                            </td>
                                        </tr>
                                        @* Detail row is hidden by default and toggled by the button above. *@
                                        <tr id="@panelId" class="bg-gray-50/60" style="display:none;">
                                            <td colspan="5" class="px-4 py-4">
                                                <div class="rounded-xl border border-gray-200 bg-white p-4">
                                                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-sm">
                                                        <div><span class="text-gray-500">Load Date Source</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.LoadDateSource) ? "N/A" : shipment.LoadDateSource)</p></div>
                                                        <div><span class="text-gray-500">Time of Day</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.TimeOfDay) ? "N/A" : shipment.TimeOfDay)</p></div>
                                                        <div><span class="text-gray-500">Load Door</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.LoadDoor) ? "N/A" : shipment.LoadDoor)</p></div>
                                                        <div><span class="text-gray-500">Load Picker</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.LoadPicker) ? "N/A" : shipment.LoadPicker)</p></div>
                                                        <div><span class="text-gray-500">Product Type</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.ProductType) ? "N/A" : shipment.ProductType)</p></div>
                                                        <div><span class="text-gray-500">Item Category Group</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.ItemCategoryGroup) ? "N/A" : shipment.ItemCategoryGroup)</p></div>
                                                        <div><span class="text-gray-500">Qty Ordered</span><p class="font-semibold text-gray-800">@shipment.QuantityOrdered.ToString("N2")</p></div>
                                                        <div><span class="text-gray-500">Qty Shipped</span><p class="font-semibold text-gray-800">@shipment.QuantityShipped.ToString("N2")</p></div>
                                                        <div><span class="text-gray-500">Price Per Unit</span><p class="font-semibold text-gray-800">@shipment.PricePerUnit.ToString("C2")</p></div>
                                                        <div><span class="text-gray-500">Total Cost of Shipped</span><p class="font-semibold text-gray-800">@shipment.TotalCostShipped.ToString("C2")</p></div>
                                                        <div><span class="text-gray-500">Total Ship Net Weight</span><p class="font-semibold text-gray-800">@shipment.TotalShipNetWeight.ToString("N2")</p></div>
                                                        <div><span class="text-gray-500">Stacks</span><p class="font-semibold text-gray-800">@(shipment.Stacks.HasValue ? shipment.Stacks.Value.ToString("N2") : "N/A")</p></div>
                                                        <div><span class="text-gray-500">Total Stacks</span><p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(shipment.TotalStacks) ? "N/A" : shipment.TotalStacks)</p></div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        /* Keep total cost masked unless the card is hovered or focused. */
        .cost-reveal-card .cost-value {
            display: none;
        }

        .cost-reveal-card:hover .cost-mask,
        .cost-reveal-card:focus .cost-mask,
        .cost-reveal-card:focus-within .cost-mask {
            display: none;
        }

        .cost-reveal-card:hover .cost-value,
        .cost-reveal-card:focus .cost-value,
        .cost-reveal-card:focus-within .cost-value {
            display: inline;
        }
    </style>

    <script>
        // Toggles one shipment detail row without posting back to the server.
        function toggleShipmentDetails(panelId, button) {
            const panel = document.getElementById(panelId);
            if (!panel) {
                return;
            }

            const isHidden = panel.style.display === 'none' || panel.style.display === '';
            panel.style.display = isHidden ? 'table-row' : 'none';
            button.textContent = isHidden ? 'Hide Details' : 'View Details';
        }
    </script>
}
