@{
    ViewData["Title"] = "Home Page";
}

<div class="min-h-[80vh] flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-8 sm:p-12 max-w-2xl w-full">
        <div class="text-center mb-8">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-800 mb-4 drop-shadow-lg">
                Joe's Data Mart
            </h1>
            <p class="text-lg sm:text-xl text-gray-600">
                Welcome to the data mart application. Test your database connection below.
            </p>
        </div>

        <div class="flex justify-center mb-8">
            <form asp-action="TestConnection" method="post" class="w-full max-w-md">
                <button type="submit" class="w-full bg-gradient-to-r from-datamart-primary to-datamart-secondary text-white font-bold py-4 px-8 rounded-full shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-lg">
                    Test Database Connection
                </button>
            </form>
        </div>

        @if (ViewBag.Status != null)
        {
            <div class="space-y-6">
                <div class="bg-white/90 rounded-xl p-6 shadow-md mx-auto max-w-lg @(ViewBag.Status.Contains("success") ? "border-l-4 border-green-500" : "border-l-4 border-red-500")">
                    <div class="flex items-center @(ViewBag.Status.Contains("success") ? "text-green-700" : "text-red-700")">
                        <div class="flex-shrink-0">
                            @if (ViewBag.Status.Contains("success"))
                            {
                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                </svg>
                            }
                            else
                            {
                                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                                </svg>
                            }
                        </div>
                        <div class="ml-3">
                            <p class="text-lg font-medium">@ViewBag.Status</p>
                        </div>
                    </div>
                </div>

                @if (ViewBag.Tables != null && ((List<(string Schema, string Name)>)ViewBag.Tables).Count > 0)
                {
                    <div class="bg-white/90 rounded-xl p-6 shadow-md">
                        <h5 class="text-xl font-semibold text-gray-800 mb-4 text-center">
                            Found @(((List<(string Schema, string Name)>)ViewBag.Tables).Count) tables (top 10):
                        </h5>
                        <div class="space-y-2 max-w-md mx-auto">
                            @foreach (var table in (List<(string Schema, string Name)>)ViewBag.Tables)
                            {
                                <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow duration-200 border border-gray-200">
                                    <div class="font-medium text-gray-800">@table.Schema.@table.Name</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="bg-red-50 border border-red-200 rounded-xl p-6 shadow-md mx-auto max-w-lg">
                        <div class="flex items-start">
                            <div class="flex-shrink-0">
                                <svg class="h-6 w-6 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <div class="ml-3">
                                <h3 class="text-lg font-medium text-red-800">Error Details</h3>
                                <div class="mt-2 text-red-700">
                                    <p>@ViewBag.Error</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>